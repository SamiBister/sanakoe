# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# TypeScript and JavaScript files
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
quote_type = single

# JSON files
[*.json]
indent_size = 2

# JSON with comments (tsconfig, etc.)
[*.jsonc]
indent_size = 2

# Package.json - use 2 spaces as per npm convention
[package.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Markdown in docs folder
[docs/**/*.md]
trim_trailing_whitespace = false
max_line_length = off

# CSS, SCSS, and related
[*.{css,scss,sass,less}]
indent_size = 2

# HTML files
[*.{html,htm}]
indent_size = 2

# SVG files
[*.svg]
indent_size = 2

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf

# Makefiles always use tabs
[Makefile]
indent_style = tab

# Git config files
[.git*]
indent_style = tab

# Don't trim trailing whitespace in diffs
[*.diff]
trim_trailing_whitespace = false

# Don't trim trailing whitespace in patches
[*.patch]
trim_trailing_whitespace = false
